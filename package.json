{
  "name": "kosha",
  "version": "0.1.0",
  "private": true,
  "description": "Kosha — a self-hosted Telegram expense tracker + net worth toolkit",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply kosha-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply kosha-db --remote",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "hono": "^4.6.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241004.0",
    "drizzle-kit": "^0.27.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
